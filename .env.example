# MiroFish Docker Configuration
# Copy this to .env and fill in your keys:
#   cp .env.example .env

# Required: Your OpenAI API key (used by MiroFish agents)
LLM_API_KEY=your_openai_api_key_here
LLM_PROVIDER=openai

# Required: Zep API key for agent memory (https://app.getzep.com)
ZEP_API_KEY=your_zep_api_key_here

# Optional: Polymarket API credentials (for live trading)
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_PASSPHRASE=
